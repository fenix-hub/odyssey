---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { render } from "astro:content";

const homepage = await getListPage("pages", "home");
const { Content } = await render(homepage);
const { title, description, meta_title, image } = homepage.data;

if (homepage.data.draft) {
  return Astro.redirect("/404");
}
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  <!-- Hero Section -->
  <section class="relative h-[70vh] w-full overflow-hidden pt-40">
    <!-- Background Gradient -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-[#2d4a6f] via-[#3d5a7f] to-[#1a2847]"></div>
      <!-- Decorative elements -->
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 container max-w-6xl mx-auto px-4">
      <div class="flex flex-col items-center justify-center text-center max-w-4xl mx-auto">
        <!-- Main Title -->
        <h1 class="text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          Benvenuto in Godot<br />Engine Italia
        </h1>

        <!-- Subtitle -->
        <p class="text-xl lg:text-2xl text-gray-200 mb-12 max-w-2xl leading-relaxed">
          Una community italiana attiva e accogliente di sviluppatori, game designer e creativi che condividono passione per Godot Engine.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8 justify-center">
          <a href="https://godotengine.org" class="bg-white text-[#333f67] font-bold py-3 px-8 rounded-lg hover:bg-gray-100 transition-colors text-lg">
            Scarica l'Engine
          </a>
          <a href="#" class="bg-[#478cbf] text-white font-bold py-3 px-8 rounded-lg hover:bg-[#3a6fa8] transition-colors text-lg">
            Ultime novità
          </a>
          <a href="#" class="border-2 border-white text-white font-bold py-3 px-8 rounded-lg hover:bg-white/10 transition-colors text-lg">
            Cosa c'è di nuovo
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest News / Community Section -->
  <section class="py-20 px-4 bg-white dark:bg-[#1a2847]">
    <div class="container max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold mb-12 text-[#333f67] dark:text-white text-center">
        Novità dalla Community
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- News Card 1 -->
        <div class="bg-gray-50 dark:bg-[#2d3e5f] rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <div class="h-48 bg-gradient-to-br from-[#478cbf] to-[#3a6fa8]"></div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-[#333f67] dark:text-white mb-3">
              Ultimi articoli del blog
            </h3>
            <p class="text-gray-600 dark:text-gray-300 mb-4">
              Scopri tutorial, guide e storie dalla community italiana di Godot Engine.
            </p>
            <a href="/blog" class="text-[#478cbf] dark:text-[#67e6bb] font-semibold hover:underline">
              Leggi di più →
            </a>
          </div>
        </div>

        <!-- News Card 2 -->
        <div class="bg-gray-50 dark:bg-[#2d3e5f] rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <div class="h-48 bg-gradient-to-br from-[#67e6bb] to-[#4ad8a6]"></div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-[#333f67] dark:text-white mb-3">
              Prossimi eventi
            </h3>
            <p class="text-gray-600 dark:text-gray-300 mb-4">
              Incontri, workshop e jam con developer, game designer e artisti della community.
            </p>
            <a href="/eventi" class="text-[#478cbf] dark:text-[#67e6bb] font-semibold hover:underline">
              Vedi gli eventi →
            </a>
          </div>
        </div>

        <!-- News Card 3 -->
        <div class="bg-gray-50 dark:bg-[#2d3e5f] rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <div class="h-48 bg-gradient-to-br from-[#8b6ce1] to-[#7a5dd3]"></div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-[#333f67] dark:text-white mb-3">
              Risorse e link utili
            </h3>
            <p class="text-gray-600 dark:text-gray-300 mb-4">
              Raccolta di tool, asset, documentazione e risorse per sviluppare con Godot.
            </p>
            <a href="/link-utili" class="text-[#478cbf] dark:text-[#67e6bb] font-semibold hover:underline">
              Scopri le risorse →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Godot Section -->
  <section class="py-20 px-4 bg-gradient-to-b from-white to-gray-50 dark:from-[#1a2847] dark:to-[#0f1827]">
    <div class="container max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold mb-12 text-[#333f67] dark:text-white text-center">
        Perché scegliere Godot Engine
      </h2>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="flex gap-4">
          <div class="flex-shrink-0">
            <div class="text-[#478cbf] text-3xl">🔓</div>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-[#333f67] dark:text-white mb-2">
              Open Source
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Completa libertà nel modificare, estendere e personalizzare l'engine secondo le tue esigenze.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0">
            <div class="text-[#67e6bb] text-3xl">⚡</div>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-[#333f67] dark:text-white mb-2">
              Leggero e veloce
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Download sotto 100 MB, avvio istantaneo, compilazione rapida per un'iterazione fluida.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0">
            <div class="text-[#8b6ce1] text-3xl">💰</div>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-[#333f67] dark:text-white mb-2">
              Completamente gratuito
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Nessuna royalty, nessun costo di licenza. Fai profitto su ciò che crei tu.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0">
            <div class="text-[#78e5f6] text-3xl">👥</div>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-[#333f67] dark:text-white mb-2">
              Community-driven
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Proponi feature, contribuisci allo sviluppo, e fai parte di una community globale.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
