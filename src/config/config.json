{
  "site": {
    "title": "Godot Engine Italia",
    "base_url": "https://astroplate.netlify.app",
    "base_path": "/",
    "trailing_slash": false,
    "favicon": "/images/cropped-logo-GE-I-150x150.png",
    "logo": "/images/logo-esteso.png",
    "logo_darkmode": "/images/logo-esteso.png",
    "logo_width": "300",
    "logo_height": "64",
    "logo_text": "Godot Engine Italia"
  },

  "settings": {
    "search": true,
    "sticky_header": true,
    "theme_switcher": true,
    "default_theme": "system",
    "pagination": 2,
    "summary_length": 200,
    "blog_folder": "blog"
  },

  "announcement": {
    "enable": true,
    "content": "<span class='text-center block'>🎮 Benvenuto in Godot Engine Italia! <a class='underline' href='#' target='_blank' rel='noopener'>Unisciti alla community →</a></span>",
    "expire_days": 7
  },

  "params": {
    "contact_form_action": "#",
    "copyright": "Godot Engine Italia - Community dedicata a Godot Engine"
  },

  "navigation_button": {
    "enable": true,
    "label": "Discord",
    "link": "#"
  },

  "google_tag_manager": {
    "enable": false,
    "gtm_id": "GTM-XXXXXX"
  },

  "disqus": {
    "enable": true,
    "shortname": "themefisher-template",
    "settings": {}
  },

  "metadata": {
    "meta_author": "Godot Engine Italia",
    "meta_image": "/images/og-image.png",
    "meta_description": "La community italiana dedicata a Godot Engine: eventi, risorse e contenuti per sviluppatori, game designer e creativi."
  }
}
